{
  "name": "@gigit/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@gigit/domain": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}